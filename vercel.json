{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python scripts/vercel_build.py",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{mobile_app/**,.git/**,.github/**,.vscode/**,render.yaml,MOBILE_API.md,PRODUCTION_ENV.md,VERCEL_DEPLOY.md,static/**,staticfiles/**,**/test_*.py}"
    }
  },
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "/staticfiles/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/api/index"
    }
  ]
}
