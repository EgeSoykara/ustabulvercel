# Vercel production profile
DJANGO_ENV=production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional for custom domains. *.vercel.app hosts are auto-added on Vercel.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Reverse proxy and security
USE_X_FORWARDED_HOST=1
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SECURE_CONTENT_TYPE_NOSNIFF=1
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
CSRF_COOKIE_HTTPONLY=0

# Vercel serverless defaults
USE_WHITENOISE=0
WEBSOCKETS_ENABLED=0
MARKETPLACE_LIFECYCLE_MODE=request
VERCEL_RUN_MIGRATIONS=1

# Automatic admin bootstrap
AUTO_SUPERUSER_ENABLED=1
AUTO_SUPERUSER_USERNAME=egesoykara
AUTO_SUPERUSER_EMAIL=admin@example.com
AUTO_SUPERUSER_PASSWORD=replace-with-strong-admin-password
AUTO_SUPERUSER_SYNC_PASSWORD=1

# Marketplace runtime
OFFER_EXPIRY_MINUTES=180
OFFER_REMINDER_MINUTES=60
APPOINTMENT_PROVIDER_CONFIRM_MINUTES=720
APPOINTMENT_CUSTOMER_CONFIRM_MINUTES=720
APPOINTMENT_SLOT_BUFFER_MINUTES=45
APPOINTMENT_MIN_LEAD_MINUTES=5
SHORT_NOTE_MAX_CHARS=100
MOBILE_LOGIN_RATE_LIMIT=20/minute
LIFECYCLE_HEARTBEAT_STALE_SECONDS=180
LIFECYCLE_LOCK_TTL_SECONDS=120
MARKETPLACE_LIFECYCLE_WEB_REFRESH_INTERVAL_SECONDS=20
NAV_STREAM_INTERVAL_SECONDS=8
NAV_STREAM_MAX_DURATION_SECONDS=55
NAV_STREAM_REOPEN_MIN_SECONDS=2
NOTIFICATION_UNREAD_CACHE_SECONDS=6
HOUSEKEEPING_INTERVAL_SECONDS=3600
IDEMPOTENCY_RETENTION_DAYS=2
WORKFLOW_EVENT_RETENTION_DAYS=90
ACTIVITY_LOG_RETENTION_DAYS=90
ERROR_LOG_RETENTION_DAYS=30

# Optional endpoints / cron auth
LIFECYCLE_HEALTH_TOKEN=replace-with-long-random-health-token
CRON_SECRET=replace-with-long-random-cron-secret
